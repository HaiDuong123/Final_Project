<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F6F8FB"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔹 PHẦN SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/avatar"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
            </LinearLayout>

            <!-- BACK + MENU -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="25dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/back"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ImageView
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:src="@drawable/menu"/>
            </LinearLayout>

            <!-- CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/result_card"
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="-10dp">

                <TextView
                    android:id="@+id/textcauhoighiam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Câu hỏi"
                    android:textColor="#1F2A44"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/txtKetQuaNoi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Câu trả lời sẽ hiển thị ở đây"
                    android:textColor="#6C7A92"
                    android:textSize="16sp"
                    android:background="#EEF1F7"
                    android:padding="12dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 🔥 PHẦN CỐ ĐỊNH -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TIMER -->
        <TextView
            android:id="@+id/textthoigianghiam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#1F2A44"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="15dp"/>

        <!-- MIC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/result_card"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginBottom="15dp">

            <ImageView
                android:id="@+id/btnbatdaughiam"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/nutghiam"/>
        </LinearLayout>

        <!-- BUTTON -->
        <LinearLayout
            android:id="@+id/btn_cautieptheo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/button_start"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoàn thành, câu tiếp theo"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>