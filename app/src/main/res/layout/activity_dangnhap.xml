<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F6F8FB"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/r9kyqjp5t2yw"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITLE CARD -->
            <LinearLayout
                android:id="@+id/rjivl92wapa_rl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/result_card"
                android:padding="24dp"
                android:orientation="vertical"
                android:layout_marginBottom="25dp">

                <TextView
                    android:id="@+id/rndysueik9qs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bắt đầu"
                    android:textColor="#1F2A44"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đăng ký hoặc đăng nhập để tiếp tục sử dụng ứng dụng."
                    android:textColor="#6C7A92"
                    android:textSize="16sp"/>

            </LinearLayout>


            <!-- SOCIAL LOGIN -->
            <LinearLayout
                android:id="@+id/rzdp8dvyier"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <!-- FACEBOOK -->
                <LinearLayout
                    android:id="@+id/rq8m1chx7akp"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/result_card"
                    android:gravity="center"
                    android:layout_marginBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/r9ne7oei56jl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng nhập bằng Facebook"
                        android:textColor="#1F2A44"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>


                <!-- GOOGLE -->
                <LinearLayout
                    android:id="@+id/rah1z6ctyps5"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/result_card"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/r8znajs3dhgk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng nhập bằng Google"
                        android:textColor="#1F2A44"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>


            <!-- LOGIN LINK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btn_dangnhap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bạn đã có tài khoản? Đăng nhập"
                    android:textColor="#4C6FFF"
                    android:textSize="15sp"/>

            </LinearLayout>


            <!-- SPACER (đẩy nút xuống dưới) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>


            <!-- REGISTER BUTTON -->
            <LinearLayout
                android:id="@+id/rgijk6x1lbug"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/button_start"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/btn_dangky"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tạo tài khoản"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>