<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F6F8FB"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/rwfra5o0d6dh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/ra70lwenn5wc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/r7p7h4cyutfy"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/avatar"
                    android:scaleType="fitXY" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kết quả phân tích"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2A44" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/rulo0va8d44"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/chuong"
                    android:scaleType="fitXY" />
            </LinearLayout>

            <!-- BACK + MENU -->
            <LinearLayout
                android:id="@+id/r9v04hnzfs25"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/rdi8fnk6ypo4"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:padding="8dp"
                    android:src="@drawable/back"
                    android:scaleType="fitXY" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- IMAGE CARD -->
            <LinearLayout
                android:id="@+id/rljd9mh7662b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="20dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ro29yxj795bn"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    app:shapeAppearanceOverlay="@style/cr40" />
            </LinearLayout>

            <!-- STATUS TEXT -->
            <TextView
                android:id="@+id/r93crw50r0cd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#7B8194"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- BUTTON -->
            <LinearLayout
                android:id="@+id/rzhw6nwu4krg"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/button_start"
                android:gravity="center"
                android:elevation="6dp"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/r1z7dtlmlpzmi"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_camera"
                    app:tint="#FFFFFF"
                    android:scaleType="fitXY" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>