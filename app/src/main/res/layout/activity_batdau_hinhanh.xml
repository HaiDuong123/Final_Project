<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F6F8FB"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/rijfd6y9a2v"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/r77wjq2s6z08"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/rsa7xgfm07t8"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/avatar"
                    android:scaleType="fitXY" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phân tích hình ảnh"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2A44" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/rh19i4lvbk95"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/chuong"
                    android:scaleType="fitXY" />
            </LinearLayout>

            <!-- BACK + MENU -->
            <LinearLayout
                android:id="@+id/r3c25e0ekjlc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/rd76jz0yyq7k"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:padding="8dp"
                    android:src="@drawable/back"
                    android:scaleType="fitXY" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- CARD TEXT -->
            <TextView
                android:id="@+id/rzzh3flyegzd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đánh giá mức độ trầm cảm thông qua hình ảnh của bạn"
                android:textColor="#1F2A44"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="10dp" />

            <!-- CARD BUTTON -->
            <LinearLayout
                android:id="@+id/rjlhf61uofxf"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/button_start"
                android:gravity="center"
                android:elevation="6dp"
                android:layout_marginHorizontal="10dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:text="Bắt đầu"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>