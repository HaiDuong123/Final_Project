<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F6F8FB"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/r06kjfe5hrxxr"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/r36h1tttdukv"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:src="@drawable/back"
                android:scaleType="fitXY"/>

            <LinearLayout
                android:id="@+id/rdqlsp8nh19p"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/r6kvuazsx6bh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1F2A44"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:text="Chào mừng"/>

            </LinearLayout>

            <TextView
                android:id="@+id/rghq74n15ccp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vui lòng nhập tài khoản của bạn để tiếp tục"
                android:textColor="#6C7A92"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="40dp"/>


            <!-- USERNAME -->

            <LinearLayout
                android:id="@+id/r0e7j1fd8jr2a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/rl7dfercc1g"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4A4A4A"
                    android:textSize="13sp"
                    android:layout_marginBottom="10dp"
                    android:text="Tên người dùng"/>

                <LinearLayout
                    android:id="@+id/rdc01s299i9i"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="#FFFFFF"
                    android:padding="15dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/user_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Nhập tên người dùng"
                        android:textSize="15sp"
                        android:textColor="#4A4A4A"
                        android:background="@null"/>

                    <ImageView
                        android:id="@+id/r8ryrcgycuqp"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/check"/>
                </LinearLayout>

            </LinearLayout>


            <!-- PASSWORD -->

            <LinearLayout
                android:id="@+id/rc0z6nunkoko"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/r5td2uh8lwli"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4A4A4A"
                    android:textSize="13sp"
                    android:layout_marginBottom="10dp"
                    android:text="Mật khẩu"/>

                <LinearLayout
                    android:id="@+id/rm1o1xx7ftnr"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="#FFFFFF"
                    android:padding="15dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/user_password"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Nhập mật khẩu"
                        android:textSize="15sp"
                        android:textColor="#4A4A4A"
                        android:inputType="textPassword"
                        android:background="@null"/>

                    <TextView
                        android:id="@+id/rd4x5hs4wag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#34C559"
                        android:textSize="11sp"
                        android:text="Mạnh"/>
                </LinearLayout>

            </LinearLayout>


            <TextView
                android:id="@+id/txtquenmatkhau"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#EA4335"
                android:textSize="14sp"
                android:text="Quên mật khẩu?"
                android:layout_gravity="end"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="40dp"/>


            <TextView
                android:id="@+id/rq2l6jr26rj"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#6C7A92"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="30dp"
                android:text="Bằng cách kết nối tài khoản của bạn, hãy xác nhận rằng bạn đồng ý với Điều khoản và Điều kiện của chúng tôi"/>


            <LinearLayout
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center"
                android:background="@drawable/button_start">

                <TextView
                    android:id="@+id/r6k9m0uac8v"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:text="Đăng nhập"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>