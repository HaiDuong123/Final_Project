<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F6F8FB"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/avatar"
                    android:scaleType="centerCrop"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/chuong"
                    android:scaleType="centerCrop"/>

            </LinearLayout>

            <!-- TITLE -->
            <TextView
                android:text="Bài kiểm tra trầm cảm PHQ-9"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Kết quả đánh giá của bạn"
                android:textSize="16sp"
                android:textColor="#777777"
                android:layout_marginBottom="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- PROGRESS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="25dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#7FA7FA"/>
            </LinearLayout>

            <TextView
                android:text="Câu hỏi 9 / 9"
                android:textSize="14sp"
                android:textColor="#777777"
                android:layout_marginBottom="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- RESULT CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/result_card"
                android:layout_marginBottom="30dp">

                <TextView
                    android:id="@+id/textketquatracnghiem"
                    android:text="Trầm cảm mức độ trung bình"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/textloikhuyentracnghiem"
                    android:text="Bạn nên cân nhắc trao đổi với bác sĩ hoặc chuyên gia sức khỏe tâm lý."
                    android:textSize="16sp"
                    android:textColor="#555555"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- MUSIC SUGGESTION -->
            <TextView
                android:id="@+id/textgoiyamnhac"
                android:text="Xem gợi ý âm nhạc dành cho bạn"
                android:textSize="16sp"
                android:textColor="#7FA7FA"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginBottom="40dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- FINISH BUTTON -->
            <LinearLayout
                android:id="@+id/btnketthuctracnghiem"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center"
                android:background="@drawable/button_start"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:text="Hoàn thành"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>